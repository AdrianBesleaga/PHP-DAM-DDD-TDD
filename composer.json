{
    "name": "interview/php-ddd-tdd",
    "description": "DDD PHP DAM system with Hexagonal Architecture, Doctrine ORM, and TDD",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.4",
        "doctrine/orm": "^3.0",
        "doctrine/dbal": "^4.0",
        "symfony/cache": "^7.0",
        "monolog/monolog": "^3.0",
        "psr/log": "^3.0",
        "webonyx/graphql-php": "^15.0",
        "firebase/php-jwt": "^7.0",
        "vlucas/phpdotenv": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "test:coverage": "phpunit --coverage-text --colors=always",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "quality": ["@analyse", "@cs:check", "@test"],
        "serve": "php -S localhost:8080 -t public",
        "db:create": "php bin/create-schema.php"
    }
}
