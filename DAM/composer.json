{
    "name": "adrian/dam",
    "description": "DAM Application with DDD, TDD, and Slim Framework",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "slim/slim": "^4.13",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "doctrine/orm": "^3.6",
        "doctrine/dbal": "^4.4",
        "symfony/cache": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
